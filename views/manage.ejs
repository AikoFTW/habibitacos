<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Management - Habibi Tacos</title>
    <meta name="description" content="Manage upcoming events for Habibi Tacos">
    <link rel="icon" type="image/png" href="assets/logos/habibitacos.png">
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary-green: #00C264;
            --accent-red: #E5272D;
            --warm-yellow: #FCD043;
            --sand-beige: #D6A14D;
            --dark-neutral: #222222;
            --white: #FFFFFF;
            --light-gray: #F8F9FA;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Fredoka', sans-serif;
            line-height: 1.6;
            color: var(--dark-neutral);
            background: linear-gradient(135deg, var(--light-gray) 0%, #e8f5e8 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: var(--white);
            padding: 15px 0;
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
        }

        .logo img {
            height: 50px;
            width: auto;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 30px;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--dark-neutral);
            font-weight: 500;
            font-size: 16px;
            transition: color 0.3s ease;
        }

        .nav-links a:hover {
            color: var(--primary-green);
        }

        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            font-size: 20px;
            color: var(--dark-neutral);
            cursor: pointer;
        }

        .manage-container {
            background: var(--white);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            padding: 40px;
            max-width: 800px;
            margin: 100px auto 20px;
        }

        .manage-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .manage-title {
            font-size: 32px;
            font-weight: 600;
            color: var(--dark-neutral);
            margin-bottom: 8px;
        }

        .manage-subtitle {
            font-size: 16px;
            color: #666;
            font-weight: 400;
        }

        .event-form {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .form-group {
            position: relative;
        }

        .form-label {
            display: block;
            font-weight: 600;
            color: var(--dark-neutral);
            margin-bottom: 8px;
            font-size: 16px;
        }

        .form-input, .form-textarea, .form-select {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #e1e5e9;
            border-radius: 12px;
            font-size: 16px;
            font-family: 'Fredoka', sans-serif;
            transition: all 0.3s ease;
            background: var(--light-gray);
        }

        .form-input:focus, .form-textarea:focus, .form-select:focus {
            outline: none;
            border-color: var(--primary-green);
            background: var(--white);
            box-shadow: 0 0 0 3px rgba(0, 194, 100, 0.1);
        }

        .form-textarea {
            resize: vertical;
            min-height: 120px;
        }

        .datetime-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .submit-btn {
            background: linear-gradient(135deg, var(--primary-green) 0%, #00a854 100%);
            color: var(--white);
            border: none;
            padding: 18px 40px;
            border-radius: 12px;
            font-size: 18px;
            font-weight: 600;
            font-family: 'Fredoka', sans-serif;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 20px;
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 194, 100, 0.3);
        }

        .submit-btn:active {
            transform: translateY(0);
        }

        .events-list {
            margin-top: 40px;
            padding-top: 40px;
            border-top: 2px solid #e1e5e9;
        }

        .events-header {
            font-size: 24px;
            font-weight: 600;
            color: var(--dark-neutral);
            margin-bottom: 20px;
            text-align: center;
        }        .event-card {
            background: var(--light-gray);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 15px;
            border-left: 4px solid var(--primary-green);
            position: relative;
        }

        .event-actions {
            position: absolute;
            top: 15px;
            right: 15px;
            display: flex;
            gap: 10px;
        }

        .action-btn {
            background: none;
            border: none;
            padding: 8px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .edit-btn {
            color: var(--primary-green);
            background: rgba(0, 194, 100, 0.1);
        }

        .edit-btn:hover {
            background: rgba(0, 194, 100, 0.2);
        }

        .delete-btn {
            color: var(--accent-red);
            background: rgba(229, 39, 45, 0.1);
        }

        .delete-btn:hover {
            background: rgba(229, 39, 45, 0.2);
        }

        .event-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--dark-neutral);
            margin-bottom: 8px;
        }

        .event-datetime {
            font-size: 14px;
            color: var(--primary-green);
            font-weight: 500;
            margin-bottom: 10px;
        }

        .event-description {
            font-size: 14px;
            color: #666;
            line-height: 1.5;
        }

        .no-events {
            text-align: center;
            color: #666;
            font-style: italic;
            padding: 40px;
        }

        @media (max-width: 768px) {
            .nav-links {
                display: none;
            }

            .mobile-menu-btn {
                display: block;
            }

            .manage-container {
                padding: 30px 25px;
                margin-top: 120px;
            }

            .manage-title {
                font-size: 28px;
            }

            .datetime-row {
                grid-template-columns: 1fr;
            }

            body {
                padding: 10px;
            }
        }

        @media (max-width: 480px) {
            .manage-container {
                padding: 25px 20px;
            }

            .form-input, .form-textarea, .form-select {
                padding: 12px 15px;
                font-size: 14px;
            }
        }
    </style>
</head>

<body>
    <%- include('partials/navbar') %>

    <div class="manage-container">
        <div class="manage-header">
            <h1 class="manage-title">Event Management</h1>
            <p class="manage-subtitle">Add and manage upcoming events</p>
        </div>

        <form class="event-form" action="/manage/add-event" method="POST">
            <div class="form-group">
                <label for="title" class="form-label">Event Title</label>
                <input type="text" id="title" name="title" class="form-input" placeholder="Enter event title" required>
            </div>

            <div class="datetime-row">
                <div class="form-group">
                    <label for="date" class="form-label">Event Date</label>
                    <input type="date" id="date" name="date" class="form-input" required>
                </div>
                <div class="form-group">
                    <label for="time" class="form-label">Event Time</label>
                    <input type="time" id="time" name="time" class="form-input" required>
                </div>
            </div>

            <div class="form-group">
                <label for="description" class="form-label">Event Description</label>
                <textarea id="description" name="description" class="form-textarea" placeholder="Enter event description" required></textarea>
            </div>

            <button type="submit" class="submit-btn">
                <i class="fas fa-plus" style="margin-right: 8px;"></i>
                Add Event
            </button>
        </form>        <div class="events-list">
            <h2 class="events-header">Upcoming Events</h2>            <% if (events && events.length > 0) { %>
                <% events.forEach(event => { %>
                    <div class="event-card" data-event-id="<%= event.id %>">
                        <div class="event-actions">
                            <button class="action-btn edit-btn" onclick="editEvent('<%= event.id %>', '<%= event.title %>', '<%= event.date %>', '<%= event.time %>', `<%= event.description %>`)">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="action-btn delete-btn" onclick="deleteEvent('<%= event.id %>', '<%= event.title %>')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                        <div class="event-title"><%= event.title %></div>
                        <div class="event-datetime">
                            <i class="fas fa-calendar-alt" style="margin-right: 5px;"></i>
                            <%= new Date(event.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                            at <%= new Date(`2000-01-01T${event.time}`).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }) %>
                        </div>
                        <div class="event-description"><%= event.description %></div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="no-events">
                    No events scheduled yet. Add your first event above!
                </div>
            <% } %>
        </div>
    </div>    <script>
        let isEditMode = false;
        let currentEditingId = null;

        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('.event-form');
            const inputs = document.querySelectorAll('.form-input, .form-textarea');
            
            inputs.forEach(input => {
                input.addEventListener('focus', function() {
                    this.parentElement.classList.add('focused');
                });
                
                input.addEventListener('blur', function() {
                    this.parentElement.classList.remove('focused');
                });
            });

            form.addEventListener('submit', function(e) {
                const title = form.querySelector('input[name="title"]').value;
                const date = form.querySelector('input[name="date"]').value;
                const time = form.querySelector('input[name="time"]').value;
                const description = form.querySelector('textarea[name="description"]').value;
                
                if (!title || !date || !time || !description) {
                    e.preventDefault();
                    alert('Please fill in all fields');
                    return;
                }
                
                const btn = form.querySelector('.submit-btn');
                if (isEditMode) {
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin" style="margin-right: 8px;"></i>Updating Event...';
                } else {
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin" style="margin-right: 8px;"></i>Adding Event...';
                }
                btn.disabled = true;
            });
        });

        function editEvent(id, title, date, time, description) {
            isEditMode = true;
            currentEditingId = id;
            
            const form = document.querySelector('.event-form');
            form.action = `/manage/edit-event/${id}`;
            
            document.querySelector('input[name="title"]').value = title;
            document.querySelector('input[name="date"]').value = date;
            document.querySelector('input[name="time"]').value = time;
            document.querySelector('textarea[name="description"]').value = description;
            
            const submitBtn = document.querySelector('.submit-btn');
            submitBtn.innerHTML = '<i class="fas fa-edit" style="margin-right: 8px;"></i>Update Event';
            
            const header = document.querySelector('.manage-subtitle');
            header.innerHTML = 'Editing event - <button onclick="cancelEdit()" style="background: none; border: none; color: var(--accent-red); cursor: pointer; text-decoration: underline;">Cancel</button>';
            
            form.scrollIntoView({ behavior: 'smooth' });
        }

        function cancelEdit() {
            isEditMode = false;
            currentEditingId = null;
            
            const form = document.querySelector('.event-form');
            form.action = '/manage/add-event';
            form.reset();
            
            const submitBtn = document.querySelector('.submit-btn');
            submitBtn.innerHTML = '<i class="fas fa-plus" style="margin-right: 8px;"></i>Add Event';
            
            const header = document.querySelector('.manage-subtitle');
            header.innerHTML = 'Add and manage upcoming events';
        }

        function deleteEvent(id, title) {
            if (confirm(`Are you sure you want to delete "${title}"? This action cannot be undone.`)) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = `/manage/delete-event/${id}`;
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
</body>

</html>
